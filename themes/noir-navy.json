    "tokenColors":  [
                        {
                            "name":  "Comment",
                            "scope":  [
                                          "comment",
                                          "punctuation.definition.comment"
                                      ],
                            "settings":  {
                                             "foreground":  "#3D59A1",
                                             "fontStyle":  "italic"
                                         }
                        },
                        {
                            "name":  "String (baseline)",
                            "scope":  [
                                          "string"
                                      ],
                            "settings":  {
                                             "foreground":  "#9ECE6A"
                                         }
                        },
                        {
                            "name":  "Keyword / Control",
                            "scope":  [
                                          "keyword",
                                          "keyword.control",
                                          "keyword.operator.new",
                                          "keyword.operator.delete",
                                          "keyword.operator.typeof",
                                          "keyword.operator.void",
                                          "keyword.operator.instanceof",
                                          "keyword.operator.in",
                                          "storage.type",
                                          "storage.modifier"
                                      ],
                            "settings":  {
                                             "foreground":  "#7DCFFF"
                                         }
                        },
                        {
                            "name":  "Operator",
                            "scope":  [
                                          "keyword.operator"
                                      ],
                            "settings":  {
                                             "foreground":  "#89DDFF"
                                         }
                        },
                        {
                            "name":  "Number / Boolean / Null",
                            "scope":  [
                                          "constant.numeric",
                                          "constant.language.boolean",
                                          "constant.language.null",
                                          "constant.language.undefined",
                                          "constant.language.nan"
                                      ],
                            "settings":  {
                                             "foreground":  "#FF9E64"
                                         }
                        },
                        {
                            "name":  "Function name / call",
                            "scope":  [
                                          "entity.name.function",
                                          "meta.function-call.generic",
                                          "support.function",
                                          "meta.function-call entity.name.function"
                                      ],
                            "settings":  {
                                             "foreground":  "#7AA2F7"
                                         }
                        },
                        {
                            "name":  "Class / Type / Interface",
                            "scope":  [
                                          "entity.name.class",
                                          "entity.name.type",
                                          "entity.name.type.class",
                                          "support.class",
                                          "support.type"
                                      ],
                            "settings":  {
                                             "foreground":  "#BB9AF7",
                                             "fontStyle":  "italic"
                                         }
                        },
                        {
                            "name":  "Variable",
                            "scope":  [
                                          "variable",
                                          "variable.other",
                                          "variable.other.readwrite"
                                      ],
                            "settings":  {
                                             "foreground":  "#C0CAF5"
                                         }
                        },
                        {
                            "name":  "Variable – parameter",
                            "scope":  [
                                          "variable.parameter"
                                      ],
                            "settings":  {
                                             "foreground":  "#E0AF68",
                                             "fontStyle":  "italic"
                                         }
                        },
                        {
                            "name":  "Variable – this / self",
                            "scope":  [
                                          "variable.language.this",
                                          "variable.language.self"
                                      ],
                            "settings":  {
                                             "foreground":  "#7DCFFF",
                                             "fontStyle":  "italic"
                                         }
                        },
                        {
                            "name":  "Property / member",
                            "scope":  [
                                          "variable.other.property",
                                          "variable.other.object.property",
                                          "support.variable.property"
                                      ],
                            "settings":  {
                                             "foreground":  "#73DACA"
                                         }
                        },
                        {
                            "name":  "Constant / enum",
                            "scope":  [
                                          "constant.other",
                                          "constant.language",
                                          "variable.other.constant",
                                          "variable.other.enummember"
                                      ],
                            "settings":  {
                                             "foreground":  "#FF9E64"
                                         }
                        },
                        {
                            "name":  "Regex / escape",
                            "scope":  [
                                          "constant.character.escape",
                                          "string.regexp",
                                          "string.regexp keyword.other"
                                      ],
                            "settings":  {
                                             "foreground":  "#7DCFFF"
                                         }
                        },
                        {
                            "name":  "Decorator / Annotation",
                            "scope":  [
                                          "meta.decorator",
                                          "entity.name.function.decorator",
                                          "punctuation.decorator"
                                      ],
                            "settings":  {
                                             "foreground":  "#E0AF68"
                                         }
                        },
                        {
                            "name":  "Invalid",
                            "scope":  [
                                          "invalid"
                                      ],
                            "settings":  {
                                             "foreground":  "#F7768E",
                                             "fontStyle":  "underline"
                                         }
