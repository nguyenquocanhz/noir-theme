    "tokenColors":  [
                        {
                            "name":  "Comment",
                            "scope":  [
                                          "comment",
                                          "punctuation.definition.comment"
                                      ],
                            "settings":  {
                                             "foreground":  "#6B3A4A",
                                             "fontStyle":  "italic"
                                         }
                        },
                        {
                            "name":  "String (baseline)",
                            "scope":  [
                                          "string"
                                      ],
                            "settings":  {
                                             "foreground":  "#FFB3D9"
                                         }
                        },
                        {
                            "name":  "Keyword / Control",
                            "scope":  [
                                          "keyword",
                                          "keyword.control",
                                          "keyword.operator.new",
                                          "keyword.operator.delete",
                                          "keyword.operator.typeof",
                                          "keyword.operator.void",
                                          "keyword.operator.instanceof",
                                          "keyword.operator.in",
                                          "storage.type",
                                          "storage.modifier"
                                      ],
                            "settings":  {
                                             "foreground":  "#FF4444"
                                         }
                        },
                        {
                            "name":  "Operator",
                            "scope":  [
                                          "keyword.operator"
                                      ],
                            "settings":  {
                                             "foreground":  "#FF79C6"
                                         }
                        },
                        {
                            "name":  "Number / Boolean / Null",
                            "scope":  [
                                          "constant.numeric",
                                          "constant.language.boolean",
                                          "constant.language.null",
                                          "constant.language.undefined",
                                          "constant.language.nan"
                                      ],
                            "settings":  {
                                             "foreground":  "#C792EA"
                                         }
                        },
                        {
                            "name":  "Function name / call",
                            "scope":  [
                                          "entity.name.function",
                                          "meta.function-call.generic",
                                          "support.function",
                                          "meta.function-call entity.name.function"
                                      ],
                            "settings":  {
                                             "foreground":  "#FF8BE8"
                                         }
                        },
                        {
                            "name":  "Class / Type / Interface",
                            "scope":  [
                                          "entity.name.class",
                                          "entity.name.type",
                                          "entity.name.type.class",
                                          "support.class",
                                          "support.type"
                                      ],
                            "settings":  {
                                             "foreground":  "#C792EA",
                                             "fontStyle":  "italic"
                                         }
                        },
                        {
                            "name":  "Variable",
                            "scope":  [
                                          "variable",
                                          "variable.other",
                                          "variable.other.readwrite"
                                      ],
                            "settings":  {
                                             "foreground":  "#F8E8F0"
                                         }
                        },
                        {
                            "name":  "Variable – parameter",
                            "scope":  [
                                          "variable.parameter"
                                      ],
                            "settings":  {
                                             "foreground":  "#FFB86C",
                                             "fontStyle":  "italic"
                                         }
                        },
                        {
                            "name":  "Variable – this / self",
