    "tokenColors": [
        {
            "name": "Comment",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#967C8E",
                "fontStyle": "italic"
            }
        },
        {
            "name": "String – general baseline (applied first, may be overridden below)",
            "scope": [
                "string"
            ],
            "settings": {
                "foreground": "#FFF1A0"
            }
        },
        {
            "name": "Template literal / backtick",
            "scope": [
                "string.quoted.backtick",
                "string.template"
            ],
            "settings": {
                "foreground": "#FFF1A0"
            }
        },
        {
            "name": "Keyword / Control",
            "scope": [
                "keyword",
                "keyword.control",
                "keyword.operator.new",
                "keyword.operator.delete",
                "keyword.operator.typeof",
                "keyword.operator.void",
                "keyword.operator.instanceof",
                "keyword.operator.in",
                "storage.type",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#FF61B6"
            }
        },
        {
            "name": "Operator",
            "scope": [
                "keyword.operator"
            ],
            "settings": {
                "foreground": "#FF61B6"
            }
        },
        {
            "name": "Number / Boolean / Null / Undefined",
            "scope": [
                "constant.numeric",
                "constant.language.boolean",
                "constant.language.null",
                "constant.language.undefined",
                "constant.language.nan"
            ],
            "settings": {
                "foreground": "#FFA3D2"
            }
        },
        {
            "name": "Function name / call",
            "scope": [
                "entity.name.function",
                "meta.function-call.generic",
                "support.function",
                "meta.function-call entity.name.function"
            ],
            "settings": {
                "foreground": "#A3F5B8"
            }
        },
        {
            "name": "Class / Type / Interface",
            "scope": [
                "entity.name.class",
                "entity.name.type",
                "entity.name.type.class",
                "support.class",
                "support.type"
            ],
            "settings": {
                "foreground": "#98E2F5",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Variable",
            "scope": [
                "variable",
                "variable.other",
                "variable.other.readwrite"
            ],
            "settings": {
                "foreground": "#F6ECEF"
            }
        },
        {
            "name": "Variable – parameter",
            "scope": [
                "variable.parameter"
            ],
            "settings": {
                "foreground": "#FFD1A9",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Variable – this / self",
            "scope": [
                "variable.language.this",
                "variable.language.self"
            ],
            "settings": {
                "foreground": "#FF61B6",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Property / member access",
            "scope": [
                "variable.other.property",
                "variable.other.object.property",
                "support.variable.property"
            ],
            "settings": {
                "foreground": "#98E2F5"
            }
        },
        {
            "name": "Constant / enum member",
            "scope": [
                "constant.other",
                "constant.language",
                "variable.other.constant",
                "variable.other.enummember"
            ],
            "settings": {
                "foreground": "#FFA3D2"
            }
        },
        {
            "name": "String escape / regex",
            "scope": [
                "constant.character.escape",
                "string.regexp",
                "string.regexp keyword.other"
            ],
            "settings": {
                "foreground": "#FF61B6"
            }
        },
        {
            "name": "Decorator / Annotation",
            "scope": [
                "meta.decorator",
                "entity.name.function.decorator",
                "punctuation.decorator"
            ],
            "settings": {
                "foreground": "#FFD1A9"
            }
        },
        {
            "name": "Invalid",
            "scope": [
                "invalid"
            ],
            "settings": {
                "foreground": "#FF8080",
                "fontStyle": "underline"
            }
        },
        {
            "name": "Deprecated",
            "scope": [
                "invalid.deprecated"
            ],
            "settings": {
                "foreground": "#FFD1A9",
                "fontStyle": "strikethrough"
            }
        },
        {
            "name": "HTML – tag name",
            "scope": [
                "entity.name.tag"
            ],
            "settings": {
                "foreground": "#FF61B6"
            }
        },
        {
            "name": "HTML – attribute name",
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#A3F5B8"
            }
        },
        {
            "name": "HTML – attribute value string",
            "scope": [
                "string.quoted.double.html",
                "string.quoted.single.html"
            ],
            "settings": {
                "foreground": "#FFF1A0"
            }
        },
        {
            "name": "CSS – selector",
            "scope": [
                "meta.selector"
            ],
            "settings": {
                "foreground": "#FF61B6"
            }
        },
        {
            "name": "CSS – property name",
            "scope": [
                "support.type.property-name.css",
                "support.type.vendored.property-name"
            ],
            "settings": {
                "foreground": "#98E2F5"
            }
        },
        {
            "name": "CSS – property value",
            "scope": [
                "meta.property-value",
                "support.constant.property-value",
                "support.constant.font-name",
                "support.constant.color"
            ],
            "settings": {
                "foreground": "#FFF1A0"
            }
        },
        {
            "name": "CSS – color hex value",
            "scope": [
                "constant.other.color.rgb-value.css"
            ],
            "settings": {
                "foreground": "#FFA3D2"
            }
        },
        {
            "name": "CSS – pseudo class/element",
            "scope": [
                "entity.other.attribute-name.pseudo-class",
                "entity.other.attribute-name.pseudo-element"
            ],
            "settings": {
                "foreground": "#FFA3D2"
            }
        },
        {
            "name": "CSS – unit",
            "scope": [
                "keyword.other.unit.css"
            ],
            "settings": {
                "foreground": "#FFD1A9"
            }
        },
        {
            "name": "Import path / module string",
            "scope": [
                "entity.name.module",
                "support.module",
                "string.quoted.double.import",
                "string.quoted.single.import"
            ],
            "settings": {
                "foreground": "#98E2F5"
            }
        },
        {
            "name": "Punctuation – braces / brackets",
            "scope": [
                "punctuation.definition.block",
                "punctuation.definition.parameters",
                "meta.brace.round",
                "meta.brace.square",
