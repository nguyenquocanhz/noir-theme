    "tokenColors":  [
                        {
                            "name":  "Comment",
                            "scope":  [
                                          "comment",
                                          "punctuation.definition.comment"
                                      ],
                            "settings":  {
                                             "foreground":  "#6272A4",
                                             "fontStyle":  "italic"
                                         }
                        },
                        {
                            "name":  "String – general baseline (applied first, may be overridden below)",
                            "scope":  [
                                          "string"
                                      ],
                            "settings":  {
                                             "foreground":  "#F1FA8C"
                                         }
                        },
                        {
                            "name":  "Template literal / backtick",
                            "scope":  [
                                          "string.quoted.backtick",
                                          "string.template"
                                      ],
                            "settings":  {
                                             "foreground":  "#F1FA8C"
                                         }
                        },
                        {
                            "name":  "Keyword / Control",
                            "scope":  [
                                          "keyword",
                                          "keyword.control",
                                          "keyword.operator.new",
                                          "keyword.operator.delete",
                                          "keyword.operator.typeof",
                                          "keyword.operator.void",
                                          "keyword.operator.instanceof",
                                          "keyword.operator.in",
                                          "storage.type",
                                          "storage.modifier"
                                      ],
                            "settings":  {
                                             "foreground":  "#FF79C6"
                                         }
                        },
                        {
                            "name":  "Operator",
                            "scope":  [
                                          "keyword.operator"
                                      ],
                            "settings":  {
                                             "foreground":  "#FF79C6"
                                         }
                        },
                        {
                            "name":  "Number / Boolean / Null / Undefined",
                            "scope":  [
                                          "constant.numeric",
                                          "constant.language.boolean",
                                          "constant.language.null",
                                          "constant.language.undefined",
                                          "constant.language.nan"
                                      ],
                            "settings":  {
                                             "foreground":  "#BD93F9"
                                         }
                        },
                        {
                            "name":  "Function name / call",
                            "scope":  [
                                          "entity.name.function",
                                          "meta.function-call.generic",
                                          "support.function",
                                          "meta.function-call entity.name.function"
                                      ],
                            "settings":  {
                                             "foreground":  "#50FA7B"
                                         }
                        },
                        {
                            "name":  "Class / Type / Interface",
                            "scope":  [
                                          "entity.name.class",
                                          "entity.name.type",
                                          "entity.name.type.class",
                                          "support.class",
                                          "support.type"
                                      ],
                            "settings":  {
                                             "foreground":  "#8BE9FD",
                                             "fontStyle":  "italic"
                                         }
                        },
                        {
                            "name":  "Variable",
                            "scope":  [
                                          "variable",
                                          "variable.other",
                                          "variable.other.readwrite"
                                      ],
                            "settings":  {
                                             "foreground":  "#F8F8F2"
                                         }
                        },
                        {
                            "name":  "Variable – parameter",
                            "scope":  [
                                          "variable.parameter"
                                      ],
                            "settings":  {
                                             "foreground":  "#FFB86C",
                                             "fontStyle":  "italic"
                                         }
                        },
                        {
                            "name":  "Variable – this / self",
                            "scope":  [
                                          "variable.language.this",
                                          "variable.language.self"
                                      ],
                            "settings":  {
                                             "foreground":  "#FF79C6",
                                             "fontStyle":  "italic"
                                         }
                        },
                        {
                            "name":  "Property / member access",
                            "scope":  [
                                          "variable.other.property",
                                          "variable.other.object.property",
                                          "support.variable.property"
                                      ],
                            "settings":  {
                                             "foreground":  "#8BE9FD"
                                         }
                        },
                        {
                            "name":  "Constant / enum member",
                            "scope":  [
                                          "constant.other",
                                          "constant.language",
                                          "variable.other.constant",
                                          "variable.other.enummember"
                                      ],
                            "settings":  {
                                             "foreground":  "#BD93F9"
                                         }
                        },
                        {
                            "name":  "String escape / regex",
                            "scope":  [
                                          "constant.character.escape",
                                          "string.regexp",
                                          "string.regexp keyword.other"
                                      ],
                            "settings":  {
                                             "foreground":  "#FF79C6"
                                         }
                        },
                        {
                            "name":  "Decorator / Annotation",
                            "scope":  [
                                          "meta.decorator",
                                          "entity.name.function.decorator",
                                          "punctuation.decorator"
                                      ],
                            "settings":  {
                                             "foreground":  "#FFB86C"
                                         }
                        },
                        {
                            "name":  "Invalid",
                            "scope":  [
