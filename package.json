				"uiTheme": "vs-dark",
				"path": "./themes/noir-soft.json"
			},
			{
				"label": "Noir (Navy)",
				"uiTheme": "vs-dark",
				"path": "./themes/noir-navy.json"
			},
			{
				"label": "Noir (Vampiric)",
				"uiTheme": "vs-dark",
				"path": "./themes/noir-vampiric.json"
			},
			{
				"label": "Noir (Sakura)",
				"uiTheme": "vs-dark",
				"path": "./themes/noir-sakura.json"
